<div class="page-header">
  <h1 class="page-title"><i class="ti ti-settings"></i><div><%= t('settings.title') %><div class="page-subtitle">System & business configuration</div></div></h1>
</div>

<form id="settingsForm" data-testid="settings-form">
  <div class="dashboard-grid">
    <div class="card">
      <div class="card-header"><div class="card-title"><i class="ti ti-building" style="color:var(--brand-primary)"></i> <%= t('settings.company') %></div></div>
      <div class="form-group"><label class="form-label"><%= t('settings.company_name') %></label><input class="form-control" name="company_name" data-testid="set-company-name"></div>
      <div class="form-group"><label class="form-label"><%= t('settings.company_phone') %></label><input class="form-control" name="company_phone"></div>
      <div class="form-group"><label class="form-label"><%= t('settings.company_address') %></label><input class="form-control" name="company_address"></div>
      <div class="form-group"><label class="form-label"><%= t('settings.receipt_footer') %></label><input class="form-control" name="receipt_footer"></div>
      <div class="form-group"><label class="form-label">Logo URL</label><input class="form-control" name="logo_url" placeholder="https://..."></div>
    </div>
    <div class="card">
      <div class="card-header"><div class="card-title"><i class="ti ti-currency-dollar" style="color:var(--brand-accent)"></i> <%= t('settings.currency') %></div></div>
      <div class="form-group"><label class="form-label"><%= t('settings.default_currency') %></label>
        <select class="form-select" name="default_currency" data-testid="set-currency"><option value="USD">USD ($)</option><option value="IQD">IQD (د.ع)</option></select>
      </div>
      <div class="form-group"><label class="form-label"><%= t('settings.exchange_rate') %></label><input class="form-control" name="exchange_rate_usd_iqd" type="number" step="0.0001" data-testid="set-rate"></div>
      <div class="form-group"><label class="form-label">Default Tax Rate (%)</label><input class="form-control" name="tax_rate" type="number" step="0.01"></div>
      <div class="form-group"><label class="form-label"><%= t('settings.default_language') %></label>
        <select class="form-select" name="default_language">
          <option value="en">English</option><option value="ar">العربية</option><option value="ku">کوردی</option>
        </select>
      </div>
      <div class="form-group"><label class="form-label">Enable Loyalty Points</label>
        <select class="form-select" name="enable_loyalty"><option value="1">Yes</option><option value="0">No</option></select>
      </div>
      <div class="form-group"><label class="form-label">Loyalty Points per Currency Unit</label><input class="form-control" name="loyalty_points_per_currency" type="number" step="0.01"></div>
    </div>
  </div>
  <div style="text-align:end;margin-top:20px"><button type="submit" class="btn btn-primary btn-lg" data-testid="save-settings"><i class="ti ti-device-floppy"></i> <%= t('settings.save_settings') %></button></div>
</form>

<script>
async function loadSettings() {
  const { data } = await API.get('/api/settings');
  const form = document.getElementById('settingsForm');
  for (const k of Object.keys(data)) {
    const el = form.elements.namedItem(k);
    if (el) el.value = data[k] || '';
  }
}
document.getElementById('settingsForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const payload = {};
  for (const [k, v] of fd.entries()) payload[k] = v;
  try { await API.post('/api/settings', payload); toast('Settings saved','success'); }
  catch(e){toast(e.message,'error');}
});
loadSettings();
</script>
