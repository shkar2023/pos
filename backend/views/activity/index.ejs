<div class="page-header">
  <h1 class="page-title"><i class="ti ti-history"></i><div><%= t('nav.activity') %><div class="page-subtitle">Recent user activity</div></div></h1>
</div>

<div class="card"><div class="table-wrap"><table class="table" data-testid="activity-table">
  <thead><tr><th>When</th><th>User</th><th>Action</th><th>Entity</th><th>Description</th><th>IP</th></tr></thead>
  <tbody>
    <% if (!logs.length) { %><tr><td colspan="6" class="empty">No activity yet</td></tr><% } %>
    <% logs.forEach(l => { %>
      <tr data-testid="log-row-<%= l.id %>">
        <td><%= h.fmtDate(l.created_at) %></td>
        <td><strong><%= l.user_name || '—' %></strong></td>
        <td><span class="badge info"><%= l.action %></span></td>
        <td><%= l.entity_type || '—' %> <% if (l.entity_id) { %>#<%= l.entity_id %><% } %></td>
        <td><%= l.description || '—' %></td>
        <td><%= l.ip || '—' %></td>
      </tr>
    <% }) %>
  </tbody>
</table></div></div>
